#!/usr/bin/env bash
# post-checkout hook: reminds developer to sync dependencies after branch switch.
set -euo pipefail

PREV_HEAD="$1"
NEW_HEAD="$2"
BRANCH_FLAG="$3"

# Only run on branch checkouts (not file checkouts)
if [[ "$BRANCH_FLAG" != "1" ]]; then
  exit 0
fi

# Check if gradle files changed between old and new HEAD
if git diff --name-only "$PREV_HEAD" "$NEW_HEAD" | grep -qE '(gradle|\.kts|libs\.versions\.toml)'; then
  echo ""
  echo "⚠️  Build files changed — consider running: ./gradlew --refresh-dependencies"
  echo ""
fi
